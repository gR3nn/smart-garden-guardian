AWS_IOT_ENDPOINT=your-endpoint-ats.iot.us-east-1.amazonaws.com
AWS_IOT_CLIENT_ID=smart-garden-rpi
AWS_IOT_CERT_PATH=/path/to/smart-garden-certs/certificate.pem.crt
AWS_IOT_KEY_PATH=/path/to/smart-garden-certs/private.pem.key
AWS_IOT_ROOT_CA_PATH=/path/to/smart-garden-certs/AmazonRootCA1.pem
AWS_IOT_COMMAND_TOPIC=smart-garden/node01/commands
AWS_IOT_STATUS_TOPIC=smart-garden/node01/status
DEVICE_ID=garden_node_01
CONTROLLER_NAME=raspberry_pi_5
RELAY_GPIO=17
RELAY_ACTIVE_LOW=true
MAX_WATERING_SECONDS=15
